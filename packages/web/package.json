{
  "name": "@prismshadow/penguin-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "PenguinHarness web frontend SPA: React + Vite + Tailwind CSS, rendering conversations streamed over the OmniMessage protocol, plus Agent configuration, model configuration, usage stats, and Traces.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "bash e2e/run.sh"
  },
  "dependencies": {
    "@prismshadow/penguin-core": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.6.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@prismshadow/penguin-server": "workspace:*",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.0"
  }
}
