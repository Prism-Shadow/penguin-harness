# Copy to .env (ignored by .gitignore) and fill in real values for local runs and e2e.
# e2e picks a Provider by available key, in order: Claude (ANTHROPIC_API_KEY) -> DeepSeek (DEEPSEEK_API_KEY).
ANTHROPIC_API_KEY=
# Optional: custom Claude gateway URL (defaults to AgentHub if unset).
# ANTHROPIC_BASE_URL=
# DeepSeek (CI's e2e uses this key, model deepseek-v4-flash).
DEEPSEEK_API_KEY=
# Optional: custom DeepSeek gateway URL (defaults to the official https://api.deepseek.com).
# DEEPSEEK_BASE_URL=
